rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Verifica si el usuario está logueado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Verifica si el usuario es Admin
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // ───────────────────────────────────────────────
    // USUARIOS (NODE_REGISTRY)
    // ───────────────────────────────────────────────
    match /users/{userId} {
      allow read: if (isAuthenticated() && request.auth.uid == userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isAuthenticated() 
                    && request.auth.uid == userId 
                    && request.resource.data.role == "user";
      
      allow update: if (isAuthenticated() && request.auth.uid == userId && request.resource.data.role == resource.data.role)
                    || isAdmin();
      
      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────────────
    // ÓRDENES (ORDER_REGISTRY)
    // ───────────────────────────────────────────────
    match /orders/{orderId} {
      // Cualquier usuario autenticado puede crear una orden
      allow create: if isAuthenticated();
      // Solo el dueño o el admin pueden leer
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // ───────────────────────────────────────────────
    // CONTACTOS (LOGISTIC_CONTACTS)
    // ───────────────────────────────────────────────
    match /contacts/{contactId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ───────────────────────────────────────────────
    // VENTA DE HARDWARE (SELL_REQUESTS)
    // ───────────────────────────────────────────────
    match /sell_requests/{requestId} {
      // El usuario debe estar logueado y el userId debe coincidir con su auth.uid
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Solo el dueño o el admin pueden leer sus solicitudes
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // ───────────────────────────────────────────────
    // PRODUCTOS Y CONFIGURACIONES
    // ───────────────────────────────────────────────
    match /products/{id} {
      allow read: if true;
      
      allow update: if isAdmin() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['selled'])
        && request.resource.data.selled == true
      ) || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['greedCounter'])
      );
      
      allow create, delete: if isAdmin();
    }

    match /locales/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /privateProducts/{id} {
      allow read, write: if isAdmin();
    }

    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
