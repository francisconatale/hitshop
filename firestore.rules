rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Verifica si el usuario está logueado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Verifica si el usuario es Admin
    // Usamos get() para leer el rol del documento del usuario
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // ───────────────────────────────────────────────
    // USUARIOS (NODE_REGISTRY)
    // ───────────────────────────────────────────────
    match /users/{userId} {
      // Un usuario lee lo suyo, un Admin lee TODO
      allow read: if (isAuthenticated() && request.auth.uid == userId) || isAdmin();
      
      // Permitir explícitamente listar la colección completa para el panel Admin
      allow list: if isAdmin();
      
      // Creación: Solo auto-registro como 'user'
      allow create: if isAuthenticated() 
                    && request.auth.uid == userId 
                    && request.resource.data.role == "user";
      
      // Update: Dueño (sin cambiar rol) o Admin (control total)
      allow update: if (isAuthenticated() && request.auth.uid == userId && request.resource.data.role == resource.data.role)
                    || isAdmin();
      
      // Delete: Solo Admin puede purgar nodos
      allow delete: if isAdmin();
    }

    // ───────────────────────────────────────────────
    // ÓRDENES (ORDER_REGISTRY)
    // ───────────────────────────────────────────────
    match /orders/{orderId} {
      allow create: if true;
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // ───────────────────────────────────────────────
    // CONTACTOS (LOGISTIC_CONTACTS)
    // ───────────────────────────────────────────────
    match /contacts/{contactId} {
      allow read: if true; // Usuarios pueden verlos para elegir el destinatario de WhatsApp
      allow write: if isAdmin(); // Solo admins gestionan la red de contactos
    }

    // ───────────────────────────────────────────────
    // VENTA DE HARDWARE (SELL_REQUESTS)
    // ───────────────────────────────────────────────
    match /sell_requests/{requestId} {
      allow create: if true; // Cualquier persona puede enviar una solicitud de venta
      allow read, update, delete: if isAdmin(); // Solo el admin puede ver y gestionar
    }

    // ───────────────────────────────────────────────
    // PRODUCTOS Y CONFIGURACIONES
    // ───────────────────────────────────────────────
    match /products/{id} {
      allow read: if true;
      
      // Permitir update si es Admin (todo), o si alguien está marcando como vendido, o si alguien incrementa el greedCounter
      allow update: if isAdmin() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['selled'])
        && request.resource.data.selled == true
      ) || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['greedCounter'])
      );
      
      allow create, delete: if isAdmin();
    }

    match /privateProducts/{id} {
      allow read, write: if isAdmin();
    }

    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}